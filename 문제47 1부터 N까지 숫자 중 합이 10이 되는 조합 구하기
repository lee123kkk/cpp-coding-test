vector<int> selected_nums;

void backtrack(int N, int sum, int start)
{
  //합이 10이면 조합을 결과에 추가하고 종료
  if( sum ==10) 
  {
    results.push_vack(selected_nums);
    return;
  }
  for (int i = start; i <= N; ++i)
  {
      //합이 10보다 작으면 가능한 조합을 계속 확인
      /if (sum + i <=10) 
       {
         selected_nums.push_back(i);
         backtrack(N, sum + i, i + 1);
         selceted_nums.pop_back();
       }
  }
}

vector<vector<int>> solution(int N)
{
  //숫자 1부터 벡트레킹 시작
  backtrack(N, 0, 1);
  return results;
}












