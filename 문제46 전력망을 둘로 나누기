#include <string>
#include <vector>
#include <cmath>  // 수학 관련 함수인 abs(절댓값)를 사용하기 위해 포함
#include <climits> // 정수형의 최댓값/최솟값 상수를 사용하기 위해 포함 (INT_MAX 등)
#include <algorithm> // remove와 min 함수를 사용하기 위해 추가

using namespace std;

//깊이 우선 탐색
int dfs(int node, int parent, const vector<vector<int>> & graph)
{
    int cnt = 1; //자기 자신을 포함하므로 1부터 시작
    // 인접 노드에 깊이 우선 탐색 계속 진행
    for (int child: graph[node])
    {
        // 무한 탐색을 방지하기 위해 노드 중 부모 노드는 탐색하지 않음
        if(child != parent)
        {
            cnt += dfs(child, node, graph); //자식 노드에 연결된 송전탑 갯수를 현재 갯수에 더함
        }
    }
    
    return cnt; //누적된 송전탑 갯수 반환
}

int solution(int n, vector<vector<int>> wires) 
{
    // graph 변수 선언 (1번 인덱스부터 사용하기 위해 n+1 크기로 생성)
    vector<vector<int>> graph(n + 1);
    
    // wire 정보를 활용해서 그래프 구축
    for (auto & wire : wires)
    {
        int a = wire[0];
        int b = wire[1];
        graph[a].push_back(b);  //a노드에서 b노드로 가는 길 기록
        graph[b].push_back(a);  //b노드에서 a노드로 가는 길 기록
    }
    
    int min_diff = INT_MAX; //갯수차이의 최소값(초기에는 아주 큰 수로 설정)
    
    for (auto & wire : wires) //모든 전선을 차례대로 끊어봄
    {
        int a = wire[0];
        int b = wire[1];
        
        // 특정 전선 임시 삭제         
        // a 노드에 연결된 리스트에서 b 노드 번호를 찾아 깔끔하게 삭제합니다.
        // remove 함수가 삭제할 원소들을 맨 뒤로 밀어내고 그 시작 위치를 반환하면,
        // erase 함수가 그 위치부터 컨테이너의 끝(end)까지 실제 메모리에서 날려버립니다.
        graph[a].erase(remove(graph[a].begin(), graph[a].end(), b), graph[a].end());
        graph[b].erase(remove(graph[b].begin(), graph[b].end(), a), graph[b].end());
        
        // 전력망을 단절하고 각 전력망의 송전탑 개수의 차이를 구함
        
        // 전선이 하나 끊어진 상태에서, a번 노드가 속한 전력망의 송전탑 개수를 DFS로 구합니다.
        int cnt_a = dfs(a, b, graph);
        // 전체 송전탑 개수(n)에서 a쪽 전력망 개수를 빼면, 반대쪽 b쪽 전력망 개수가 나옵니다.
        int cnt_b = n - cnt_a; 
        
        //현재 송전탑 개수 차이의 절댓값이 최솟값과 현재 값 중 더 적은 값을 택함
        min_diff = min(min_diff, abs(cnt_a - cnt_b));
        
        // 임시로 제거했던 전선을 복구
        graph[a].push_back(b);
        graph[b].push_back(a);
    }
    
    return min_diff;
}








